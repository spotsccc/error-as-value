{
  "name": "errore",
  "version": "0.14.1",
  "type": "module",
  "description": "Type-safe errors as values for TypeScript. Like Go, but with full type inference.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spotsccc/error-as-value.git"
  },
  "homepage": "https://github.com/spotsccc/error-as-value#readme",
  "bugs": {
    "url": "https://github.com/spotsccc/error-as-value/issues"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "errore": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "skills"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc && tsc -p tsconfig.cjs.json && node -e \"const fs = require('node:fs'); fs.copyFileSync('package.cjs.json', 'dist/cjs/package.json'); fs.chmodSync('dist/cli.js', 0o755)\"",
    "test": "vitest",
    "test:package": "node scripts/verify-package.mjs",
    "test:install": "node scripts/verify-git-install.mjs",
    "prepare": "npm run build",
    "bench": "bun run benchmarks/effect-vs-errore.ts",
    "bench:create-tagged-error": "bun run benchmarks/create-tagged-error.ts",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "keywords": [
    "error",
    "result",
    "typescript",
    "type-safe",
    "go",
    "errors-as-values"
  ],
  "author": "remorses",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@code-hike/lighter": "^1.0.3",
    "effect": "^3.19.18",
    "hono": "^4.11.5",
    "marked": "^17.0.5",
    "mitata": "^1.0.34",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
